# DOCKERFILE - Vite React SPA with NGINX
# Generated by Code-to-Cloud Enterprise v1.7
# RULE 74: Use nginx-unprivileged for non-root security contexts
# RULE 73: Use npm install --legacy-peer-deps (not npm ci)
# ════════════════════════════════════════════════════════════════════════════

# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# RULE 73: Use npm install with legacy-peer-deps for Lovable-generated apps
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Build the application
RUN npm run build

# Stage 2: Production
# RULE 74: Use nginx-unprivileged for runAsNonRoot: true compatibility
FROM nginxinc/nginx-unprivileged:alpine

# Copy custom nginx configuration
COPY .opsera-clarity-withai-1/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# nginx-unprivileged already has correct permissions, no need to modify
# Port 8080 is used because non-root users cannot bind to ports < 1024

# Expose port 8080 (nginx-unprivileged default)
EXPOSE 8080

# Health check on port 8080
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/ || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
