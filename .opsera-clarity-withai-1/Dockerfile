# ════════════════════════════════════════════════════════════════════════════
# DOCKERFILE - Vite React SPA with NGINX
# Generated by Code-to-Cloud Enterprise v1.7
# RULE 74: Use nginx-unprivileged for non-root security contexts
# RULE 73: Use npm install --legacy-peer-deps (not npm ci)
# ════════════════════════════════════════════════════════════════════════════

# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# RULE 73: Use npm install with legacy-peer-deps for Lovable-generated apps
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Build the application
RUN npm run build

# Stage 2: Production
# RULE 74: Use nginx-unprivileged for runAsNonRoot: true compatibility
FROM nginxinc/nginx-unprivileged:alpine

# Copy custom nginx configuration
COPY .opsera-clarity-withai-1/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# RULE 33: NGINX container permissions
USER root
RUN mkdir -p /var/cache/nginx/client_temp \
    /var/cache/nginx/proxy_temp \
    /var/cache/nginx/fastcgi_temp \
    /var/cache/nginx/uwsgi_temp \
    /var/cache/nginx/scgi_temp \
    && chmod -R 777 /var/cache/nginx \
    && chmod -R 777 /var/log/nginx \
    && touch /var/run/nginx.pid \
    && chmod 777 /var/run/nginx.pid

# Switch back to non-root user
USER nginx

# Expose port 80
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
